@page "/"

<PageTitle>Product Pricing</PageTitle>

@if (isLoading)
{
    <p>Loading...</p>
}
else if (products is not null)
{
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Price</th>
                <th>Last Updated</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in products)
            {
                <tr>
                    <td>@product.Id</td>
                    <td>@product.Name</td>
                    <td>@product.Price.ToString("C")</td>
                    <td>@product.LastUpdated.ToString("dd/MM/yyyy HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
}
else if (errorMessage is not null)
{
    <p class="text-danger">@errorMessage</p>
}
